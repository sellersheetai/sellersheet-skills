{
  "_meta": {
    "description": "Index of SellerSheet SP report tables. Load this first, then load reference/<table>.json for column details.",
    "naming_convention": "Table names ARE the Amazon report types: 'rpt_' + report_type lowercased. Renamed 2026-07-10 (migration d5f7a9c1e3b5). The old internal names (rpt_listings_snapshot, rpt_restock_recommendations, rpt_account_health, ...) still resolve as read-only compat VIEWs — prefer the canonical names below.",
    "tables_deliberately_not_amazon_named": {
      "rpt_orders": "Fed by TWO order report types (GET_FLAT_FILE_ALL_ORDERS_DATA_BY_ORDER_DATE_GENERAL for the one-shot 30-day backfill, ..._BY_LAST_UPDATE_GENERAL for the hourly incremental) — no single report type to name it after.",
      "rpt_sp_purchased_products": "Fed by two report types; keeps its shorthand name.",
      "rpt_sp_* / rpt_sb_* / rpt_sd_*": "Ads-API tables — already Amazon-derived names.",
      "rpt_dk_*": "Data Kiosk GraphQL datasets, not SP-API report types.",
      "rpt_noon_*": "noon.com, not Amazon.",
      "listing_images": "Enrichment cache, not a report.",
      "rpt_inventory_age / rpt_inventory_adjustments / rpt_sales_and_traffic": "Retired — left under their legacy names for legacy reads only.",
      "rpt_fba_shipments / rpt_seller_feedback": "PII, frozen — no writes, no rename."
    },
    "queryable_via": "query_report_data",
    "enable_via": "enable_report_sync",
    "trigger_via": "trigger_report_sync",
    "list_via": "list_report_syncs",
    "pii_tables": [
      "rpt_fba_shipments",
      "rpt_seller_feedback"
    ],
    "poll_only_tables": [
      "rpt_get_v2_settlement_report_data_flat_file_v2"
    ]
  },
