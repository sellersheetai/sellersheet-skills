  "_meta": {
    "table": "rpt_get_fba_fulfillment_customer_returns_data",
    "naming_note": "Renamed 2026-07-10 (migration d5f7a9c1e3b5) — the table name IS the Amazon report type. The old name `rpt_fba_returns` still resolves as a read-only compat VIEW; prefer `rpt_get_fba_fulfillment_customer_returns_data` in new queries.",
    "report_type": "GET_FBA_FULFILLMENT_CUSTOMER_RETURNS_DATA",
    "is_snapshot": false,
