{
  "_meta": {
    "table": "rpt_afn_inventory_by_country",
    "report_type": "GET_AFN_INVENTORY_DATA_BY_COUNTRY",
    "is_snapshot": true,
    "description": "Country-level FBA inventory for NARF-enrolled sellers. One row per (sku, country) showing quantity available for local fulfillment in that country. Pairs with rpt_afn_inventory: that table holds the pan-NA pool total; this one holds the per-country split.",
    "pii": false,
    "queryable": true,
    "deprecated": false,
    "strategy": "request",
    "date_column": "snapshot_date",
    "unique_key": [
      "store_id",
      "snapshot_date",
      "fnsku",
      "country",
      "condition_type"
    ],
    "cron": "0 */6 * * *"
  },
  "columns": [
    {"db_column": "seller_sku",                     "amazon_header": "seller-sku",                     "type": "str"},
    {"db_column": "fnsku",                          "amazon_header": "fulfillment-channel-sku",        "type": "str"},
    {"db_column": "asin",                           "amazon_header": "asin",                           "type": "str"},
    {"db_column": "condition_type",                 "amazon_header": "condition-type",                 "type": "str"},
    {"db_column": "country",                        "amazon_header": "country",                        "type": "str", "values": ["GB", "DE", "FR", "IT", "ES", "PL", "NL", "BE", "SE", "IE", "US", "CA", "MX"]},
    {"db_column": "quantity_for_local_fulfillment", "amazon_header": "quantity-for-local-fulfillment", "type": "int"},
    {"db_column": "snapshot_date",                  "amazon_header": "(injected by ingest worker)",    "type": "date"}
  ],
  "example_query": {
    "store": "novaStore-UK",
    "tables": ["rpt_afn_inventory_by_country"],
    "columns": [
      "rpt_afn_inventory_by_country.seller_sku",
      "rpt_afn_inventory_by_country.country",
      "rpt_afn_inventory_by_country.quantity_for_local_fulfillment"
    ],
    "filters": [
      {"column": "rpt_afn_inventory_by_country.country", "op": "eq", "value": "GB"}
    ],
    "order_by": [{"column": "rpt_afn_inventory_by_country.quantity_for_local_fulfillment", "dir": "desc"}],
    "limit": 50,
    "report_date": "latest"
  }
}
