{
  "_meta": {
    "table": "rpt_get_afn_inventory_data",
    "naming_note": "Renamed 2026-07-10 (migration d5f7a9c1e3b5) — the table name IS the Amazon report type. The old name `rpt_afn_inventory` still resolves as a read-only compat VIEW; prefer `rpt_get_afn_inventory_data` in new queries.",
    "report_type": "GET_AFN_INVENTORY_DATA",
    "is_snapshot": true,
    "description": "AFN sellable inventory snapshot per SKU/FNSKU.",
    "pii": false,
    "queryable": true,
    "deprecated": false,
    "strategy": "request",
    "date_column": "snapshot_date",
    "unique_key": [
      "store_id",
      "snapshot_date",
      "fnsku",
      "warehouse_condition_code",
      "condition_type"
    ],
    "cron": "0 */6 * * *",
    "retention_days": 7,
    "retention_note": "rows older than 7 days are pruned nightly (newest snapshot per store never pruned where applicable); query beyond the window returns a report_date_note"
  },
  "columns": [
    {
      "db_column": "seller_sku",
      "amazon_header": "seller-sku",
      "type": "str"
    },
    {
      "db_column": "fnsku",
      "amazon_header": "fulfillment-channel-sku",
      "type": "str"
    },
    {
      "db_column": "asin",
      "amazon_header": "asin",
      "type": "str"
    },
    {
      "db_column": "condition_type",
      "amazon_header": "condition-type",
      "type": "str"
    },
    {
      "db_column": "warehouse_condition_code",
      "amazon_header": "Warehouse-Condition-code",
      "type": "str"
    },
    {
      "db_column": "quantity_available",
      "amazon_header": "Quantity Available",
      "type": "int"
    }
  ],
  "example_query": {
    "store": "myStore-AE",
    "tables": [
      "rpt_get_afn_inventory_data"
    ],
    "columns": [
      "rpt_get_afn_inventory_data.seller_sku",
      "rpt_get_afn_inventory_data.fnsku",
      "rpt_get_afn_inventory_data.asin"
    ],
    "filters": [],
    "order_by": [
      {
        "column": "rpt_get_afn_inventory_data.seller_sku",
