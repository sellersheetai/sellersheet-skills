{
  "_meta": {
    "table": "rpt_sp_campaign_negative_targets",
    "report_type": "spCampaignNegativeTargets",
    "is_snapshot": true,
    "description": "Sponsored Products campaign-level negative product targets. Daily snapshot — every fire upserts the full current set. Sourced via Ads-API v3 paginated POST /sp/campaignNegativeTargets/list. Campaign-level negatives apply to ALL ad groups within the campaign — distinct from rpt_sp_negative_targets (ad-group scope).",
    "pii": false,
    "queryable": true,
    "deprecated": false,
    "strategy": "ads_list",
    "date_column": "snapshot_date",
    "unique_key": ["store_id", "profile_id", "snapshot_date", "target_id"],
    "cron": "36 4 * * *"
  },
  "columns": [
    {"db_column": "store_id", "type": "str", "comment": "Owning store (FK amazon_stores.store_id)."},
    {"db_column": "profile_id", "type": "str", "comment": "Amazon Ads profile id."},
    {"db_column": "snapshot_date", "type": "date", "comment": "Marketplace-local date the snapshot was captured."},
    {"db_column": "ingested_at", "type": "datetime", "comment": "Server-side timestamp the row was UPSERTed."},
    {"db_column": "target_id", "type": "str", "comment": "Amazon's target identifier."},
    {"db_column": "campaign_id", "type": "str", "comment": "Campaign id this negative scopes to."},
    {"db_column": "targeting_expression", "type": "str", "comment": "JSON-stringified array of Amazon's targeting clauses (asinSameAs / asinCategorySameAs / asinBrandSameAs)."},
    {"db_column": "expression_type", "type": "str", "comment": "'MANUAL' | 'AUTO'."},
    {"db_column": "state", "type": "str", "comment": "'ENABLED' | 'PAUSED' | 'ARCHIVED' | 'USER_DELETED'."},
    {"db_column": "extra", "type": "json", "comment": "Any Amazon response fields not promoted to a typed column."}
  ],
  "example_query": {
    "store": "myStore-AE",
    "tables": ["rpt_sp_campaign_negative_targets"],
    "columns": [
      "rpt_sp_campaign_negative_targets.targeting_expression",
      "rpt_sp_campaign_negative_targets.campaign_id"
    ],
    "filters": [
      {"column": "rpt_sp_campaign_negative_targets.state", "op": "=", "value": "ENABLED"}
    ],
    "snapshot_date": "latest",
    "limit": 100
  }
}
