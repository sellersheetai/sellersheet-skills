    "queryable": true,
    "deprecated": false,
    "strategy": "request",
    "date_column": "snapshot_date",
    "unique_key": [
      "store_id",
      "snapshot_date",
      "seller_sku",
      "country_code",
      "item_condition"
    ],
    "cron": "0 6 * * *"
  },
