  "notes": [
    "main_image_url and listing_status are NOT in this table. They live in listing_images (persistent cache).",
    "To get images alongside snapshot data, query listing_images separately by seller_sku."
  ],
  "example_query": {
    "store": "myStore-AE",
    "tables": [
      "rpt_listings_snapshot"
    ],
    "columns": [
      "rpt_listings_snapshot.seller_sku",
      "rpt_listings_snapshot.item_name",
      "rpt_listings_snapshot.asin1",
      "rpt_listings_snapshot.price",
      "rpt_listings_snapshot.quantity",
      "rpt_listings_snapshot.status",
      "rpt_listings_snapshot.fulfillment_channel"
    ],
    "filters": [
      {"column": "rpt_listings_snapshot.quantity", "op": "gt", "value": 0}
    ],
    "order_by": [
      {
        "column": "rpt_listings_snapshot.seller_sku",
        "dir": "asc"
      }
    ],
    "limit": 100,
    "report_date": "latest"
  }
