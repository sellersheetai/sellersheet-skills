{
  "_meta": {
    "table": "rpt_dk_sales_traffic_by_date",
    "report_type": "DK_SALES_TRAFFIC_BY_DATE",
    "is_snapshot": false,
    "description": "Store-level daily Sales & Traffic KPIs (one row per store/marketplace/day). Sourced from Amazon Data Kiosk GraphQL `analytics_salesAndTraffic_2024_04_24` (salesAndTrafficByDate, DAY granularity) — NOT the legacy GET_SALES_AND_TRAFFIC_REPORT. Amazon's nested `Amount {amount, currencyCode}` objects are unwrapped: the numeric money columns (ordered_product_sales, average_selling_price, etc.) hold `.amount`, and `currency_code` holds the single shared currency for the row. `unit_session_percentage` is the conversion-rate metric (units_ordered / sessions); `buy_box_percentage` is the buy-box (featured offer) win rate. Use for store-wide daily sales/traffic trends and the TACOS denominator.",
    "pii": false,
    "queryable": true,
    "deprecated": false,
    "strategy": "data_kiosk",
    "date_column": "date",
    "unique_key": [
      "store_id",
      "date",
      "country_code"
    ],
    "cron": "18 1 * * *",
    "retention_days": 730,
    "retention_note": "rows older than 730 days are pruned nightly (newest snapshot per store never pruned where applicable); query beyond the window returns a report_date_note"
  },
