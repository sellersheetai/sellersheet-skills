{
  "_meta": {
    "table": "rpt_get_merchant_listings_all_data",
    "naming_note": "Renamed 2026-07-10 (migration d5f7a9c1e3b5) — the table name IS the Amazon report type. The old name `rpt_listings_snapshot` still resolves as a read-only compat VIEW; prefer `rpt_get_merchant_listings_all_data` in new queries.",
    "report_type": "GET_MERCHANT_LISTINGS_ALL_DATA",
    "is_snapshot": true,
    "description": "Daily all-listings snapshot for merchant catalog state.",
    "pii": false,
    "queryable": true,
    "deprecated": false,
    "strategy": "request",
    "date_column": "snapshot_date",
    "unique_key": [
      "store_id",
      "snapshot_date",
      "seller_sku",
      "country_code",
      "item_condition"
    ],
    "cron": "10 4 * * *",
    "retention_days": 7,
    "retention_note": "rows older than 7 days are pruned nightly (newest snapshot per store never pruned where applicable); query beyond the window returns a report_date_note"
  },
