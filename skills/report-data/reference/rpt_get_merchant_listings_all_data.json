      "rpt_get_merchant_listings_all_data.status",
      "rpt_get_merchant_listings_all_data.fulfillment_channel"
    ],
    "filters": [
      {
        "column": "rpt_get_merchant_listings_all_data.quantity",
        "op": "gt",
        "value": 0
      }
    ],
    "order_by": [
      {
        "column": "rpt_get_merchant_listings_all_data.seller_sku",
        "dir": "asc"
      }
    ],
    "limit": 100,
    "report_date": "latest"
  }
