{
  "_comment_": "SellerSheet MCP server config — paste this into your agent's MCP config file. See https://sellersheetai.com/dashboard for your API key.",
  "mcpServers": {
    "sellersheet": {
      "command": "npx",
      "args": ["-y", "@sellersheet/mcp-server"],
      "env": {
        "SELLERSHEET_API_KEY": "YOUR_API_KEY_FROM_sellersheetai.com/dashboard"
      }
    }
  },
  "_per_agent_paths_": {
    "claude-desktop": {
      "macos": "~/Library/Application Support/Claude/claude_desktop_config.json",
      "linux": "~/.config/Claude/claude_desktop_config.json",
      "windows": "%APPDATA%/Claude/claude_desktop_config.json"
    },
    "claude-code": {
      "_": "Use /mcp add or ~/.claude/mcp.json"
    },
    "codex": {
      "_": "~/.codex/mcp.json or codex CLI flag --mcp"
    },
    "gemini-cli": {
      "_": "~/.gemini/mcp.json"
    },
    "antigravity": {
      "_": "~/.antigravity/mcp.json"
    }
  },
  "_setup_steps_": [
    "1. Sign in at https://sellersheetai.com",
    "2. Visit /dashboard and copy your API key",
    "3. Replace YOUR_API_KEY_FROM_sellersheetai.com/dashboard above with your key",
    "4. Merge the mcpServers block into your agent's MCP config file (see _per_agent_paths_)",
    "5. Restart your agent",
    "6. Run a test tool call (e.g. get_user_context) to confirm the connection"
  ]
}
